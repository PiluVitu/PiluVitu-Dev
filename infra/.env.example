# Cloudflare Tunnel token — gerado em:
#   dash.cloudflare.com → Zero Trust → Networks → Tunnels → Create a tunnel
#   → Tipo "Cloudflared" → copie o valor que aparece no docker run
#
# Copie este arquivo para infra/.env (NÃO commit) e cole seu token:
#   cp infra/.env.example infra/.env
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoi...cole-aqui

# Override opcional dos origins do CORS (lista separada por vírgula).
# Default usado se omitido: http://localhost:3333,https://piluvitu.com.br
# CORS_ALLOWED_ORIGINS=http://localhost:3333,https://piluvitu.com.br,https://staging.piluvitu.com.br

# Hoist next and related packages to root node_modules so eslint-config-next
# can resolve them in a pnpm monorepo (eslint-config-next uses CJS require for next internals)
hoist-pattern[]=next
public-hoist-pattern[]=next

# Hoist zod: @hookform/resolvers@5.x importa `zod/v4/core` mas não declara
# zod como peerDependency, então o resolver não encontra a subpath pelo walk-up
# do .pnpm. Manter zod também como devDep da raiz garante o hoist.
public-hoist-pattern[]=zod

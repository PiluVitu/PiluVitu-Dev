# Keystatic (modo GitHub — ver https://keystatic.com/docs/github-mode )
# Cria a GitHub App ao visitar /keystatic em dev; copia os valores gerados para aqui e para a Vercel.
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Opcional: repo `owner/name` (default no código: PiluVitu/PiluVitu-Dev)
# KEYSTATIC_GITHUB_REPO=PiluVitu/PiluVitu-Dev

# No GitHub App > Callback URL, inclui:
# - http://localhost:3000/api/keystatic/github/oauth/callback
# - https://<teu-dominio>/api/keystatic/github/oauth/callback
